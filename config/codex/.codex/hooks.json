{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cmux-notify 'Codex CLI'",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "cmux-notify 'Codex CLI'",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
