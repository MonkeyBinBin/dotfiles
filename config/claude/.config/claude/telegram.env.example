# cc-notify.sh 的 Telegram 設定與可調參數。
# 複製為 ~/.config/claude/telegram.env 並填入實際值（此檔含 secret，不納入版控）。
#   cp telegram.env.example ~/.config/claude/telegram.env
#
# 取得方式：
#   TELEGRAM_BOT_TOKEN  向 @BotFather 建立 bot 後取得
#   TELEGRAM_CHAT_ID    對 bot 傳一則訊息，再查
#                       https://api.telegram.org/bot<TOKEN>/getUpdates 的 chat.id

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# 選用：完成通知的行為調整（未設定則用腳本內建預設）
# 主 agent 閒置幾秒才發通知（trailing-edge debounce 窗口）
CC_NOTIFY_IDLE_WINDOW=25
# 主 turn 短於這秒數就不通知
CC_NOTIFY_MIN_SECONDS=30
