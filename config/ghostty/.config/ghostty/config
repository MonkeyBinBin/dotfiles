# 字型設定
font-family = JetBrains Mono
font-size = 14

# 視窗設定
window-padding-x = 8
window-padding-y = 4
window-decoration = true

# 佈景主題
theme = Gruvbox Dark

# 游標設定
cursor-style = block
cursor-style-blink = true

# 滑鼠與選取
copy-on-select = clipboard
mouse-hide-while-typing = true

# Shell 整合
shell-integration = zsh

# macOS 專用設定
macos-option-as-alt = left
macos-titlebar-style = tabs

# 視窗尺寸（啟動時的欄數與列數）
window-width = 120
window-height = 35

# Scrollback 設定
# AI agent 輸出量大，預設 10MB 可能不足，調高至 50MB
scrollback-limit = 52428800

# 剪貼簿整合
# 允許終端程式透過 OSC 52 寫入系統剪貼簿（AI agent 常透過此機制複製內容）
clipboard-read = ask
clipboard-write = allow

# 連結偵測
# 自動偵測終端輸出中的 URL，方便快速開啟 AI agent 產生的連結
link-url = true

# 非焦點分割面板的透明度，方便辨識目前操作的面板
unfocused-split-opacity = 0.5

# 快速鍵 — 分割視窗（vim 風格 h/j/k/l）
keybind = cmd+d=new_split:right
keybind = cmd+shift+d=new_split:down
keybind = ctrl+opt+shift+cmd+h=goto_split:left
keybind = ctrl+opt+shift+cmd+l=goto_split:right
keybind = ctrl+opt+shift+cmd+k=goto_split:top
keybind = ctrl+opt+shift+cmd+j=goto_split:bottom

# 快速鍵 — 分割視窗大小調整（vim 風格 h/j/k/l）
keybind = cmd+ctrl+h=resize_split:left,40
keybind = cmd+ctrl+l=resize_split:right,40
keybind = cmd+ctrl+k=resize_split:up,20
keybind = cmd+ctrl+j=resize_split:down,20

# 快速鍵 — 常用操作
keybind = cmd+shift+c=copy_url_to_clipboard
